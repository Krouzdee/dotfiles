// -*- mode: jsonc -*-
{
    "layer": "top",
    "position": "top", 
    "height": 42, 
    "spacing": 2, 
    "modules-left": [
        "custom/arch",
        "hyprland/workspaces"
    ],
    "modules-center": [],
    "modules-right": [
	    "tray",
	    "custom/spacer",
        "pulseaudio",
        "network",
        "hyprland/language",
        "clock",
	    "custom/power"
    ],
    //Modules configuration

    "include": [
		"~/.config/waybar/modules.json"
	]
}
